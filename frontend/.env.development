# API URL — Uses Vite proxy in development to avoid CORS issues
# URL del API — Usa el proxy de Vite en desarrollo para evitar problemas de CORS
# The proxy in vite.config.ts rewrites /api/* → http://localhost:3000/api/*
# El proxy en vite.config.ts reescribe /api/* → http://localhost:3000/api/*
VITE_API_URL=/api
