# Frontend Environment Variables
# Copy this to .env and fill in your values

# API URL
VITE_API_URL=http://localhost:3000/api

# Sentry (optional - for error monitoring)
VITE_SENTRY_DSN=

# PWA Feature Flags (all disabled by default in development - opt-in)
# Set to 'true' to enable features

# Enable PWA functionality (service worker, manifest)
# VITE_PWA_ENABLED=true

# Enable offline support for landing pages and public profiles
# Requires VITE_PWA_ENABLED=true
# VITE_PWA_OFFLINE=true

# Push Notifications (requires VAPID keys configured in backend)
# Push notifications are opt-in (user must explicitly subscribe)
# No env var needed - controlled by user permission in browser

# Feature Flags / Flags de funcionalidad
VITE_FEATURE_CRYPTO_WALLET=false
