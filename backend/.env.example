# Backend Environment Variables

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5434
DB_DIALECT=postgres
DB_NAME=mlm_db
DB_USER=mlm
DB_PASSWORD=mlm123

# Test Database (PostgreSQL)
TEST_DB_HOST=localhost
TEST_DB_PORT=5435
TEST_DB_NAME=mlm_test
TEST_DB_USER=mlm_test
TEST_DB_PASSWORD=mlm_test

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (optional - disable if not using)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Two-Factor Authentication (2FA)
# Generate a 64-character hex key: openssl rand -hex 32
TWO_FACTOR_SECRET_KEY=change-this-to-a-64-char-hex-key-generate-with-openssl-rand-hex-32

# Brevo Email (SMTP Relay)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_smtp_user_brevo
BREVO_SMTP_PASS=your_smtp_pass_brevo
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Nexo Real

# Brevo SMS API
BREVO_API_KEY=your_api_key_brevo
BREVO_SMS_SENDER=NexoReal

# Wallet Digital Configuration
WALLET_MIN_WITHDRAWAL=20
WALLET_FEE_PERCENTAGE=5
WALLET_CRON_TIME=0 0 * * *

# Skip Commission Calculation (for testing)
# Set to 'true' in integration tests to prevent timeouts
# Unit tests should NOT set this (commission calculation is mocked)
SKIP_COMMISSION_CALCULATION=false

# Sentry Error Tracking (optional - for production)
# Get your DSN from: https://sentry.io/settings/
SENTRY_DSN=

# Docker Production
VERSION=latest

# VAPID Keys for Web Push Notifications
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BEOFMjxTnElyqtP7fjyfI-jmU-aC0CG5l32Dk2hpP3GkuC3Q5k0Et4DaRywVypeCcQkyQDrT-vDq0gh5_iJGuW0
VAPID_PRIVATE_KEY=u58ftlRL1wcq0ICUt4EOCFUhiUquGqhU1vTYzIThnFk
VAPID_SUBJECT=mailto:admin@nexoreal.com # TODO: domain pending

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# MercadoPago Configuration (Colombia)
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key
MERCADOPAGO_WEBHOOK_ID=your_mercadopago_webhook_id
MERCADOPAGO_INTEGRATION_TYPE=checkout

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=nexoreal-media
R2_PUBLIC_URL=https://media.nexoreal.xyz

# Internal Webhook Secret (for n8n → backend communication)
# Secreto de webhook interno (para comunicación n8n → backend)
INTERNAL_WEBHOOK_SECRET=change-this-to-a-random-32-char-secret

# n8n Webhook URL for Google Calendar sync
# URL del webhook de n8n para sincronización con Google Calendar
N8N_CALENDAR_WEBHOOK_URL=https://n8n.nexoreal.xyz/webhook/calendar-sync

