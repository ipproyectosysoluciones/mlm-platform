# Backend Environment Variables

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mlm_db
DB_USER=root
DB_PASSWORD=rootpassword

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (optional - disable if not using)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Brevo Email (SMTP Relay)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_smtp_user_brevo
BREVO_SMTP_PASS=your_smtp_pass_brevo
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=MLM Platform

# Brevo SMS API
BREVO_API_KEY=your_api_key_brevo
BREVO_SMS_SENDER=MLMPlatform
