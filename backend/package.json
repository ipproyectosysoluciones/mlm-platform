{
  "name": "mlm-backend",
  "version": "1.0.0",
  "description": "MLM Binary Affiliations Platform - Backend",
  "main": "dist/server.cjs",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "node scripts/build.mjs",
    "build:watch": "node scripts/build.mjs --watch",
    "build:tsc": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:integration": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand",
    "test:integration:auth": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/auth.test.ts",
    "test:integration:validation": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/validation.test.ts",
    "test:integration:pagination": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/pagination.test.ts",
    "test:integration:tree": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/tree.test.ts",
    "test:integration:rbac": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/rbac.test.ts",
    "test:integration:crm": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/crm.test.ts",
    "test:integration:products": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/products-orders.test.ts",
    "test:integration:commissions": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/commissions.test.ts",
    "test:integration:tree-visual": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/tree-visual.test.ts",
    "test:integration:performance": "TEST_DB_NAME=mlm_test jest --config=jest.integration.config.js --runInBand --testPathPattern=integration/performance.test.ts",
    "test:unit": "NODE_ENV=test jest --testPathIgnorePatterns=integration",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "seed": "ts-node src/seed.ts"
  },
  "keywords": [
    "mlm",
    "binary",
    "affiliations",
    "network-marketing"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@sentry/node": "^10.46.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/qrcode": "^1.5.6",
    "@types/sqlite3": "^5.1.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
