# ===========================================
# MLM Platform - .gitignore
# ===========================================

# ===========================================
# Dependencies
# ===========================================
node_modules/
.pnpm-store/

# ===========================================
# Build outputs
# ===========================================
dist/
build/

# ===========================================
# Environment (CRITICAL - NEVER commit)
# ===========================================
.env
.env.local
.env.*.local
.env.production
.env.production.local

# ===========================================
# Logs
# ===========================================
logs/
*.log
npm-debug.log*

# ===========================================
# OS files
# ===========================================
.DS_Store
Thumbs.db

# ===========================================
# IDE - User specific (keep .vscode/settings.json)
# ===========================================
.idea/
*.swp
*.swo

# ===========================================
# Test coverage
# ===========================================
coverage/
.nyc_output/

# ===========================================
# Docker
# ===========================================
.dockerignore

# ===========================================
# Playwright
# ===========================================
test-results/
playwright-report/
playwright/.cache/
frontend/test-screenshots/

# ===========================================
# Temporary files
# ===========================================
tmp/
temp/
*.tmp

# ===========================================
# Database
# ===========================================
*.sqlite
*.db

# ===========================================
# Credentials
# ===========================================
credentials.json
secrets/

# ===========================================
# TypeScript cache
# ===========================================
*.tsbuildinfo

# ===========================================
# Project specific - Internal/AI tools (not needed for dev)
# ===========================================
.atl/                               # AI agent skill registry (internal)
.sdd/*/apply-progress/              # SDD apply progress (internal)
openspec/

# ===========================================
# API Testing files (Postman collections - use docs/API.md instead)
# ===========================================
postman/

# ===========================================
# Deploy scripts (configure on server, not in repo)
# ===========================================
deploy.sh
deploy.prod.sh

# ===========================================
# Sentry
# ===========================================
.sentryclirc

# ===========================================
# Misc
# ===========================================
*.tgz
*.tar.gz
