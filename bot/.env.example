# ─── WhatsApp Bot ─────────────────────────────────────────────────────────────

# WhatsApp phone number linked to the bot (international format, no + or spaces)
# Example: Colombia 300 123 4567 → 573001234567
PHONE_NUMBER=573001234567

# Port where the bot's internal HTTP server listens
BOT_PORT=3002

# Secret shared between bot and MLM backend (must match backend's BOT_SECRET)
BOT_SECRET=change_me_in_production

# ─── OpenAI — Nexo Bot AI (Sophia + Max) ─────────────────────────────────────

# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# Model: gpt-4o-mini for testing (cheap), gpt-4o for production (better)
OPENAI_MODEL=gpt-4o-mini

# ─── MLM Backend ──────────────────────────────────────────────────────────────

# Internal Docker network URL to the MLM backend
MLM_BACKEND_URL=http://backend:3000/api

# ─── PostgreSQL (same instance as MLM backend) ────────────────────────────────

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mlm_platform
