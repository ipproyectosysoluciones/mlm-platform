{
  "name": "mlm-platform",
  "private": true,
  "version": "1.0.0",
  "description": "MLM Binary Affiliations Platform",
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "npm run test --workspaces --if-present"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "picomatch": "4.0.4",
    "prettier": "^3.5.3"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3"
    },
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "esbuild",
      "sqlite3"
    ]
  }
}
